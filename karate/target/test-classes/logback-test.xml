<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{40} — %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Karate's own logger produces the scenario output we want -->
    <logger name="com.intuit.karate" level="INFO"/>
    <!-- Suppress Apache HttpClient wire logging -->
    <logger name="org.apache.http" level="WARN"/>
    <logger name="org.apache.http.wire" level="OFF"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
